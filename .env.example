# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# ─────────────────────────────────────────
# Auth
# ─────────────────────────────────────────
AUTH_SECRET=your-random-32-char-secret             # openssl rand -base64 32
CRON_SECRET=optional-vercel-cron-secret            # protects /api/cron/cleanup-locks in production

# ─────────────────────────────────────────
# Thermal Printer
# ─────────────────────────────────────────
PRINTER_HOST=192.168.1.100                         # printer IP on LAN
PRINTER_PORT=9100                                  # raw ZPL port (default 9100)

# ─────────────────────────────────────────
# Shopee Open API (per app — covers all shops)
# ─────────────────────────────────────────
SHOPEE_APP_ID=your-app-id
SHOPEE_APP_KEY=your-app-key
SHOPEE_API_BASE=https://partner.shopeemobile.com   # use https://partner.test-stable.shopeemobile.com for sandbox

# ─────────────────────────────────────────
# Lazada Open API
# ─────────────────────────────────────────
LAZADA_APP_KEY=your-app-key
LAZADA_APP_SECRET=your-app-secret
LAZADA_API_BASE=https://api.lazada.co.th/rest       # TH endpoint
LAZADA_AUTH_BASE=https://auth.lazada.com
LAZADA_REDIRECT_URI=https://your-domain.vercel.app/api/admin/lazada/callback

# ─────────────────────────────────────────
# Labelary (PDF → ZPL conversion)
# ─────────────────────────────────────────
LABELARY_API_URL=http://api.labelary.com/v1/printers/8dpmm/labels/4x6/0/
# Free, no API key needed — rate limit: 1 req/sec
# If high volume: self-host or use zpl-image npm package as fallback

# ─────────────────────────────────────────
# n8n (for reference — n8n pushes to Supabase directly)
# ─────────────────────────────────────────
# n8n runs at: https://n8n.nongkoko.cloud
# n8n uses SUPABASE_SERVICE_ROLE_KEY to write orders
# No webhook URL needed in this app — n8n is push-only
