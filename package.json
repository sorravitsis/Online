{
  "name": "awb-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "next lint",
    "test": "node --require ./tests/helpers/register-ts.cjs ./tests/run-tests.cjs",
    "print:agent": "node --require ./tests/helpers/register-ts.cjs ./scripts/local-print-agent.cjs",
    "seller-center:profiles": "node ./scripts/generate-seller-center-profiles.cjs",
    "seller-center:login": "node ./scripts/seller-center-agent.cjs --login",
    "seller-center:agent": "node ./scripts/seller-center-agent.cjs",
    "preflight": "npm exec tsc --noEmit && npm test && npm run build",
    "seed:load-test": "node --require ./tests/helpers/register-ts.cjs ./scripts/seed-load-test.cjs",
    "verify:load-test": "node --require ./tests/helpers/register-ts.cjs ./scripts/verify-load-test.cjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "next": "^14.2.0",
    "playwright-core": "^1.54.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
